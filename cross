def is_yt_playlist(url):
    if not any(x in url for x in ('youtube.com','youtu.be')): return False
    m = re.search(r'[?&]list=([^&]+)', url)
    return bool(m) and not m.group(1).startswith(('RD','LL','WL','FL'))

# ─── File naming ──────────────────────────────────────────────────────────────
def camel(s):
    s = re.sub(r'[<>:"/\\|?*\x00-\x1f]','',s)
    return ''.join(w.capitalize() for w in re.split(r'[\s\-_–—]+',s.strip()) if w)

def build_name(title, artist, mode):
    if mode == 'mp3':
        if not artist:
            m = re.match(r'^(.+?)\s*[-–—]\s*(.+)$', title)
            if m: artist, title = m.group(1).strip(), m.group(2).strip()
        t,a = camel(title), camel(artist) if artist else ''
        return f"{t}-{a}" if a else t
    return camel(title)

def pl_folder(name):
    return re.sub(r'[\s\-–—]+','_', re.sub(r'[<>:"/\\|?*\x00-\x1f]','',name).strip()).lower().strip('_')

def unique(path):
    if not os.path.exists(path): return path
    base, ext = os.path.splitext(path)
    sep = '_' if not ext else ''
    i = 1
    while os.path.exists(f"{base}{sep}({i:02d}){ext}"): i += 1
    return f"{base}{sep}({i:02d}){ext}"

