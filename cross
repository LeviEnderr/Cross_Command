# ─── Spotify scraping ─────────────────────────────────────────────────────────
_UA = 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'

def sp_fetch(url):
    req = urllib.request.Request(url, headers={'User-Agent':_UA,'Accept-Language':'en-US,en;q=0.9'})
    with urllib.request.urlopen(req, timeout=12) as r: return r.read().decode('utf-8','ignore')

def sp_track_info(url):
    try:
        tid = url.split('/track/')[1].split('?')[0]
        # Titolo via oEmbed
        with urllib.request.urlopen(
            f'https://open.spotify.com/oembed?url=https://open.spotify.com/track/{tid}',
            timeout=10) as r:
            title = json.loads(r.read()).get('title','')
        # Artista via embed
        req = urllib.request.Request(
            f'https://open.spotify.com/embed/track/{tid}',
            headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=10) as r:
            html = r.read().decode('utf-8','ignore')
        a = re.search(r'"artists".*?"name":"([^"]+)"', html)
        return title or None, (a.group(1) if a else None)
    except: return None, None

def _sp_parse(data):
    tracks = []
    try:
        entity = data['props']['pageProps']['state']['data']['entity']
        for item in (entity.get('trackList') or []):
            t,a = item.get('title',''), item.get('subtitle','')
            if t: tracks.append((unescape(t), unescape(a)))
        if not tracks:
            for item in entity.get('tracks',{}).get('items',[]):
                trk = item.get('track') or item
                t   = trk.get('name','')
                a   = ', '.join(x['name'] for x in trk.get('artists',[]) if x.get('name'))
                if t: tracks.append((t, a))
    except: pass
    return tracks

def sp_playlist_tracks(url):
    kind = 'playlist' if '/playlist/' in url else 'album'
    pid  = url.split(f'/{kind}/')[1].split('?')[0]
    tracks = []; html = ''
    for endpoint in [f'https://open.spotify.com/embed/{kind}/{pid}',
                     f'https://open.spotify.com/{kind}/{pid}']:
        try:
            html = sp_fetch(endpoint)
            m = re.search(r'<script id="__NEXT_DATA__"[^>]*>(.+?)</script>', html, re.DOTALL)
            if m:
                tracks = _sp_parse(json.loads(m.group(1)))
                if tracks: break
        except: continue
    if not tracks and html:
        tracks = [(unescape(m.group(1)),'') for m in
                  re.finditer(r'"name"\s*:\s*"([^"]+)"[^}]*"@type"\s*:\s*"MusicRecording"', html, re.DOTALL)]
    return tracks

def sp_playlist_name(url):
    try:
        kind = 'playlist' if '/playlist/' in url else 'album'
        pid  = url.split(f'/{kind}/')[1].split('?')[0]
        html = sp_fetch(f'https://open.spotify.com/{kind}/{pid}')
        m    = re.search(r'<meta property="og:title" content="([^"]+)"', html)
        return unescape(m.group(1)) if m else 'playlist'
    except: return 'playlist'

# ─── Playlist UI ──────────────────────────────────────────────────────────────
def pl_select_ui(entries, name, folder):
    TW = 54
    brow = lambda s: f"  {G}║{RS} {s}{' '*max(0,TW-vlen(s))} {G}║{RS}"
    print(f"\n  {G}╔{'═'*(TW+2)}╗{RS}")
    print(brow(f"{W}{B}{name[:TW]}{RS}"))
    print(brow(f"{D}{len(entries)} tracks  →  {folder}/{RS}"))
    print(f"  {G}╠{'═'*(TW+2)}╣{RS}")
    for i,e in enumerate(entries[:8],1): print(brow(f"{D}{i:2}.{RS}  {(e.get('title') or '?')[:48]}"))
    if len(entries)>8: print(brow(f"{D}     ... and {len(entries)-8} more{RS}"))
    print(f"  {G}╠{'═'*(TW+2)}╣{RS}")
    print(brow(f"{D}Download: number / all / 1-5 (range){RS}"))
    print(f"  {G}╚{'═'*(TW+2)}╝{RS}")
    while True:
        try: s = input(f"\n  {CY}>{RS} ").strip().lower()
        except KeyboardInterrupt: print(); sys.exit(0)
        if s in ('all','a'): return entries
        if s.isdigit() and 1<=int(s)<=len(entries): return entries[:int(s)]
        m = re.match(r'^(\d+)-(\d+)$',s)
        if m:
            lo,hi = int(m.group(1))-1,int(m.group(2))
            if 0<=lo<hi<=len(entries): return entries[lo:hi]
        print(f"  {Y}invalid — try: all, 5, 2-8{RS}")

def pl_final(downloaded, failed, dest):
    TW = 54
    brow = lambda s: f"  {G}║{RS} {s}{' '*max(0,TW-vlen(s))} {G}║{RS}"
    clr(); print()
    print(f"  {G}╔{'═'*(TW+2)}╗{RS}")
    print(brow(f"{G}✓  {len(downloaded)}/{len(downloaded)+len(failed)} tracks downloaded{RS}"))
    print(brow(f"{D}{os.path.abspath(dest)[:TW]}{RS}"))
    if failed:
        print(f"  {G}╠{'═'*(TW+2)}╣{RS}")
        print(brow(f"{R}not found ({len(failed)}):{RS}"))
        for item in failed: print(brow(f"  {R}✗  {item[:TW-4]}{RS}"))
    print(f"  {G}╚{'═'*(TW+2)}╝{RS}\n")

# ─── Playlist download ────────────────────────────────────────────────────────
def dl_sp_playlist(url, dest):
    os.makedirs(dest, exist_ok=True)
    print(f"\n  {D}fetching Spotify playlist...{RS}")
    tracks = sp_playlist_tracks(url)
    if not tracks: err("Could not read playlist tracks. Try opening it in a browser first.")
    name   = sp_playlist_name(url)
    folder = pl_folder(name)
    dest   = unique(os.path.join(dest, folder))
    os.makedirs(dest, exist_ok=True)
    selected = pl_select_ui([{'title':t,'artist':a} for t,a in tracks], name, folder)
    downloaded, failed = [], []
    for i,entry in enumerate(selected,1):
        title, artist = entry['title'], entry.get('artist','')
        try:
            import yt_dlp
            query = f"{title} {artist} official audio".strip() if artist else f"{title} official audio"
            tmp   = f"__cross_{int(time.time())}_{i}"
            P.reset(); P.set_pl(i, len(selected), title)
            P.set_ctx(title=title, artist=artist, source='spotify', mode='mp3', dest=os.path.abspath(dest))
            P.render()
            with yt_dlp.YoutubeDL(dl_opts(dest, tmp, 'mp3', P.hook)) as ydl:
                ydl.download([f"ytsearch1:{query}"])
            downloaded.append(finalize(dest, tmp, 'mp3', build_name(title, artist, 'mp3')))
        except KeyboardInterrupt: print(f"\n  {Y}⚠  Cancelled.{RS}"); sys.exit(0)
        except: failed.append(f"{title} — {artist}" if artist else title)
    pl_final(downloaded, failed, dest)
    return downloaded

def dl_yt_playlist(url, mode, dest):
    try: import yt_dlp
    except: err("yt-dlp not found.")
    print(f"\n  {D}fetching playlist...{RS}")
    with yt_dlp.YoutubeDL(base_opts({'extract_flat':True})) as ydl:
        pl = ydl.extract_info(url, download=False)
    entries = pl.get('entries',[])
    name    = pl.get('title','Playlist')
    folder  = pl_folder(name)
    dest    = unique(os.path.join(dest, folder))
    os.makedirs(dest, exist_ok=True)
    selected = pl_select_ui(entries, name, folder)
    downloaded, failed = [], []
    for i,vid in enumerate(selected,1):
        vid_id  = vid.get('id','').strip()
        vid_url = vid.get('url','').strip()
        if vid_id and not vid_url.startswith('http'):
            vid_url = f"https://www.youtube.com/watch?v={vid_id}"
        title_v = vid.get('title') or '?'
        if not vid_url or vid_url.endswith('v='):
            failed.append(f"{title_v} — no URL"); continue
        P.set_pl(i, len(selected), title_v); P._ctx = {}
        try:
            try: downloaded.append(dl_single(vid_url, mode, dest))
            except SystemExit: failed.append(f"{title_v} — private or unavailable")
        except KeyboardInterrupt: raise
        except Exception as e: failed.append(f"{title_v} — {str(e)[:50]}")
    pl_final(downloaded, failed, dest)
    return downloaded

