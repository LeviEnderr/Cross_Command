# ─── Main ─────────────────────────────────────────────────────────────────────
def main():
    args = sys.argv[1:]
    if not args or args[0] in ('-h','--help'): print_help(); sys.exit(0)

    playlist = '-p' in args; args = [a for a in args if a != '-p']
    url=None; mode=None; dest='.'
    for a in args:
        if   a=='-mp3': mode='mp3'
        elif a=='-mp4': mode='mp4'
        elif not a.startswith('-'): url,dest = (a,dest) if url is None else (url,os.path.expanduser(a))

    if not url:  err("No URL specified.")
    check_url(url)
    if not mode: err("Specify -mp3 or -mp4.")
    if 'spotify.com' in url and mode=='mp4':      err("Spotify only supports -mp3.")
    if is_sp_playlist(url) and not playlist:      err("Spotify playlist — add -p flag.")
    if is_yt_playlist(url) and not playlist:      err("YouTube playlist — add -p flag.")

    os.makedirs(dest, exist_ok=True)

    if   is_sp_track(url):               r = dl_spotify(url, dest);         box([f"{G}✓  {os.path.basename(r)[:48]}{RS}", f"{D}{os.path.abspath(dest)}{RS}"]); print()
