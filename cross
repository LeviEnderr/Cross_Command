# ─── yt-dlp opts ──────────────────────────────────────────────────────────────
def base_opts(extra=None):
    o = dict(quiet=True, no_warnings=True, logger=_Log(),
             retries=10, fragment_retries=10, socket_timeout=30,
             hls_prefer_ffmpeg=True,
             js_runtimes={'node':{}}, remote_components={'ejs:github'})
    if _CK: o['cookiesfrombrowser'] = _CK
    if extra: o.update(extra)
    return o

def dl_opts(dest, tmp, mode, hook):
    o = base_opts({'progress_hooks':[hook],
                   'outtmpl': os.path.join(dest, f'{tmp}.%(ext)s')})
    if mode == 'mp3':
        o['format'] = '140/251/139/249/18/bestaudio'
        o['postprocessors'] = [{'key':'FFmpegExtractAudio','preferredcodec':'mp3','preferredquality':'320'}]
    else:
        o['format'] = '137+140/136+140/135+140/248+251/bestvideo+bestaudio/best'
        o['merge_output_format'] = 'mp4'
    return o

def get_info(url):
    try:
        import yt_dlp
        with yt_dlp.YoutubeDL(base_opts({'skip_download':True})) as ydl:
            return ydl.extract_info(url, download=False)
    except Exception as e: err(f"Could not read URL: {e}")

# ─── Progress ─────────────────────────────────────────────────────────────────
class Progress:
    def __init__(self): self.reset()

    def reset(self):
        self.pct=0.0; self.spd=''; self.eta=''; self.done=False
        self.files=set(); self.last=-1.0; self.pl_cur=0; self.pl_tot=0; self.pl_title=''

    def set_pl(self, cur, tot, title=''):
        self.pl_cur=cur; self.pl_tot=tot; self.pl_title=title

    def hook(self, d):
        key = d.get('filename', id(d))
        if d['status'] == 'downloading' and key not in self.files:
            try: pct = float(_ANSI.sub('',d.get('_percent_str','0%')).strip().replace('%',''))
            except: return
            if pct - self.last < 0.5: return
            self.pct=pct; self.last=pct
            self.spd=d.get('_speed_str','').strip(); self.eta=d.get('_eta_str','').strip()
            self.done=False; self.render()
        elif d['status'] == 'finished' and key not in self.files:
            self.pct=100.0; self.last=100.0; self.done=True
            self.files.add(key); self.render()

    def render(self):
        p = self.pct; done = self.done
        bar = f"{G}{'█'*25}{RS} {G}✓{RS}" if done else \
              f"{G}{'█'*int(p/4)}{D}{'░'*(25-int(p/4))}{RS}"
        pct_s = "100%" if done else f"{p:5.1f}%"
        spd_s = '' if done else (f"  {D}{self.spd}{RS}" if self.spd else '')
        eta_s = '' if done else (f"  {D}ETA {self.eta}{RS}" if self.eta else '')

        src  = self._ctx.get('source','')
        icon = ('♫' if src=='spotify' else '▶') if not IS_WIN else ('?' if src=='spotify' else '>')
        mode = self._ctx.get('mode','mp3')
        RW   = 46
        rp   = lambda s: s+' '*max(0,RW-vlen(s))

        menu = [rp(f"{icon} {CY}{'Spotify' if src=='spotify' else 'YouTube'}{RS}  {D}|{RS}  {W}{B}{'MP3 · 320kbps' if mode=='mp3' else 'MP4 · best'}{RS}"),
                rp(f"{D}{'─'*RW}{RS}")]
        if self._ctx.get('artist'): menu.append(rp(f"{D}artist {RS}{W}{self._ctx['artist'][:36]}{RS}"))
        menu += [rp(f"{D}title  {RS}{W}{B}{self._ctx.get('title','')[:36]}{RS}"),
                 rp(f"{D}dest   {RS}{D}{self._ctx.get('dest','')[:36]}{RS}"),
                 rp(f"{D}{'─'*RW}{RS}"),
                 rp(f"{bar} {pct_s}{spd_s}{eta_s}")]
        if self.pl_cur and self.pl_tot:
            menu.append(rp(f"{D}track  {RS}{W}{self.pl_cur}/{self.pl_tot}{RS}  {D}{self.pl_title[:24]}{RS}"))

        asc = ['']*max(0,(len(menu)-len(SMALL))//2) + [f"{G}{l}{RS}" for l in SMALL]
        asc += [''] * max(0, len(menu)-len(asc))
        clr(); print()
        for i,ml in enumerate(menu):
            a = asc[i] if i<len(asc) else ''
            print(f"  {a}{' '*max(0,10-vlen(a))}  {ml}")
        print()

    def set_ctx(self, **kw): self._ctx = kw
    _ctx = {}

P = Progress()

# ─── Finalize ─────────────────────────────────────────────────────────────────
def finalize(dest, tmp, mode, name):
    ext   = 'mp3' if mode=='mp3' else 'mp4'
    found = glob.glob(os.path.join(dest, f'{tmp}*'))
    path  = unique(os.path.join(dest, f'{name}.{ext}'))
    if not found: return path
    src = found[0]
    if mode == 'mp4':
        r = subprocess.run(['ffmpeg','-y','-fflags','+genpts','-i',src,
                            '-c','copy','-avoid_negative_ts','make_zero',
                            '-movflags','+faststart',path],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if r.returncode == 0:
            try: os.remove(src)
            except: pass
        else:
            try: os.rename(src, path)
            except: pass
    else:
        os.rename(src, path)
    return path

# ─── Download ─────────────────────────────────────────────────────────────────
def dl_single(url, mode, dest):
    try: import yt_dlp
    except: err("yt-dlp not found.")
    os.makedirs(dest, exist_ok=True)
    info   = get_info(url)
    title  = info.get('title','Unknown'); artist = info.get('artist') or ''
    P.reset(); P.set_ctx(title=title, artist=artist, source='youtube', mode=mode,
                         dest=os.path.abspath(dest))
    P.render()
    tmp = f"__cross_{int(time.time())}"
    try:
        with yt_dlp.YoutubeDL(dl_opts(dest, tmp, mode, P.hook)) as ydl: ydl.download([url])
    except yt_dlp.utils.DownloadError as e: err(str(e))
    except KeyboardInterrupt: print(f"\n  {Y}⚠  Cancelled.{RS}"); sys.exit(0)
    return finalize(dest, tmp, mode, build_name(title, artist, mode))

